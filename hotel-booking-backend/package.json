{
  "name": "booking-backend",
  "version": "0.2.1",
  "description": "booking mern app backend",
  "main": "./dist/src/index.js",
  "scripts": {
    "build": "tsc --skipLibCheck",
    "build-local": "tsc --skipLibCheck",
    "lint": "tsc --noEmit",
    "start": "node dist/src/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "e2e": "cross-env DOTENV_CONFIG_PATH=.env.e2e nodemon",
    "init-db": "ts-node scripts/init-database.ts",
    "check-db": "ts-node scripts/startup-check.ts",
    "seed": "ts-node scripts/seed-database.ts",
    "migrate-three-tier": "npx ts-node scripts/migrate-to-three-tier-system.ts",
    "init-super-admin": "npx ts-node scripts/init-super-admin.ts",
    "setup-three-tier": "npm run migrate-three-tier && npm run init-super-admin",
    "test-feedback": "npx ts-node scripts/test-feedback-system.ts",
    "promote-admin": "npx ts-node scripts/promote-user-to-admin.ts",
    "test-auth-perf": "npx ts-node scripts/test-auth-performance.ts",
    "test-admin-mgmt": "npx ts-node scripts/test-admin-management.ts",
    "optimize-auth": "npx ts-node scripts/optimize-auth-indexes.ts",
    "migrate-to-atlas": "npx ts-node scripts/migrate-to-atlas.ts",
    "simple-migrate": "npx ts-node scripts/simple-migrate.ts",
    "full-migrate": "npx ts-node scripts/full-database-migrate.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "author": "Arnob Mahmud",
  "license": "ISC",
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.16",
    "@types/csurf": "^1.11.5",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/luxon": "^3.7.1",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.9.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "axios": "^1.8.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "csurf": "^1.11.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.2",
    "mongodb": "^6.2.0",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "nodemon": "^3.0.1",
    "prom-client": "^15.1.3",
    "stripe": "^14.8.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "@supabase/supabase-js": "^2.39.8",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "tsx": "^4.7.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^6.0.2",
    "jest": "^30.3.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0"
  }
}
